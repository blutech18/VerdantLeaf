{% comment %}
  Verdant Leaf — Standout Interactive Feature: Tea Profile Quiz
  Multi-step quiz that recommends teas based on user preferences
  Uses scoring logic to match answers to tea categories
{% endcomment %}

<section class="section section--dark" id="tea-quiz">
  <div class="container">
    <div class="quiz" id="quiz-container">

      <!-- Start Screen -->
      <div class="quiz__screen quiz__screen--start active" data-screen="start">
        <div class="quiz__intro text-center">
          <span class="quiz__intro-label">The Tea Concierge</span>
          <h2 class="quiz__intro-title">{{ 'quiz.title' | t }}</h2>
          <p class="quiz__intro-text">
            Answer a few simple questions about your palate and preferences, and we will curate a personalized selection of Verdant Leaf teas just for you.
          </p>
          <button class="btn btn--gold btn--lg quiz__start-btn" id="quiz-start">
            {{ 'quiz.start' | t }}
          </button>
        </div>
      </div>

      <!-- Question 1: Flavor Preference -->
      <div class="quiz__screen" data-screen="q1" data-question="1">
        <div class="quiz__progress">
          <div class="quiz__progress-bar" style="width: 25%;"></div>
        </div>
        <div class="quiz__step-label">Question 1 of 4</div>
        <h3 class="quiz__question">{{ 'quiz.q1_title' | t }}</h3>
        <div class="quiz__options" data-question="flavor">
          <button class="quiz__option" data-value="floral" data-scores='{"green":3,"white":3,"oolong":1,"herbal":2}'>
            <span class="quiz__option-emoji"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M12 2v3"/><path d="M12 19v3"/><path d="M22 12h-3"/><path d="M5 12H2"/><path d="M19 5l-2 2"/><path d="M7 17l-2 2"/><path d="M19 19l-2-2"/><path d="M7 7L5 5"/></svg></span>
            <span class="quiz__option-text">{{ 'quiz.q1_o1' | t }}</span>
          </button>
          <button class="quiz__option" data-value="earthy" data-scores='{"puerh":3,"oolong":2,"black":1,"green":1}'>
            <span class="quiz__option-emoji"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg></span>
            <span class="quiz__option-text">{{ 'quiz.q1_o2' | t }}</span>
          </button>
          <button class="quiz__option" data-value="rich" data-scores='{"black":3,"puerh":2,"oolong":2}'>
            <span class="quiz__option-emoji"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg></span>
            <span class="quiz__option-text">{{ 'quiz.q1_o3' | t }}</span>
          </button>
          <button class="quiz__option" data-value="fruity" data-scores='{"herbal":3,"white":2,"green":1,"oolong":1}'>
            <span class="quiz__option-emoji"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 20.94c1.5 0 2.75 1.06 4 1.06 3 0 6-8 6-12.22A4.91 4.91 0 0 0 17 5c-2.22 0-4 1.44-5 2-1-.56-2.78-2-5-2a4.9 4.9 0 0 0-5 4.78C2 14 5 22 8 22c1.25 0 2.5-1.06 4-1.06Z"/><path d="M10 2c1 .5 2 2 2 5"/></svg></span>
            <span class="quiz__option-text">{{ 'quiz.q1_o4' | t }}</span>
          </button>
        </div>
      </div>

      <!-- Question 2: Caffeine Level -->
      <div class="quiz__screen" data-screen="q2" data-question="2">
        <div class="quiz__progress">
          <div class="quiz__progress-bar" style="width: 50%;"></div>
        </div>
        <div class="quiz__step-label">Question 2 of 4</div>
        <h3 class="quiz__question">{{ 'quiz.q2_title' | t }}</h3>
        <div class="quiz__options" data-question="caffeine">
          <button class="quiz__option" data-value="none" data-scores='{"herbal":4}'>
            <span class="quiz__option-emoji"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg></span>
            <span class="quiz__option-text">{{ 'quiz.q2_o1' | t }}</span>
          </button>
          <button class="quiz__option" data-value="low" data-scores='{"white":3,"green":2,"herbal":1}'>
            <span class="quiz__option-emoji"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg></span>
            <span class="quiz__option-text">{{ 'quiz.q2_o2' | t }}</span>
          </button>
          <button class="quiz__option" data-value="moderate" data-scores='{"green":2,"oolong":3,"white":1}'>
            <span class="quiz__option-emoji"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg></span>
            <span class="quiz__option-text">{{ 'quiz.q2_o3' | t }}</span>
          </button>
          <button class="quiz__option" data-value="high" data-scores='{"black":3,"puerh":2,"oolong":1}'>
            <span class="quiz__option-emoji"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg></span>
            <span class="quiz__option-text">{{ 'quiz.q2_o4' | t }}</span>
          </button>
        </div>
      </div>

      <!-- Question 3: Time of Day -->
      <div class="quiz__screen" data-screen="q3" data-question="3">
        <div class="quiz__progress">
          <div class="quiz__progress-bar" style="width: 75%;"></div>
        </div>
        <div class="quiz__step-label">Question 3 of 4</div>
        <h3 class="quiz__question">{{ 'quiz.q3_title' | t }}</h3>
        <div class="quiz__options" data-question="time">
          <button class="quiz__option" data-value="morning" data-scores='{"black":3,"puerh":2,"oolong":1}'>
            <span class="quiz__option-emoji"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 18a5 5 0 0 0-10 0"/><line x1="12" y1="2" x2="12" y2="9"/><line x1="4.22" y1="10.22" x2="5.64" y2="11.64"/><line x1="1" y1="18" x2="3" y2="18"/><line x1="21" y1="18" x2="23" y2="18"/><line x1="18.36" y1="11.64" x2="19.78" y2="10.22"/><line x1="23" y1="22" x2="1" y2="22"/><polyline points="8 6 12 2 16 6"/></svg></span>
            <span class="quiz__option-text">{{ 'quiz.q3_o1' | t }}</span>
          </button>
          <button class="quiz__option" data-value="afternoon" data-scores='{"oolong":3,"green":2,"white":1}'>
            <span class="quiz__option-emoji"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg></span>
            <span class="quiz__option-text">{{ 'quiz.q3_o2' | t }}</span>
          </button>
          <button class="quiz__option" data-value="evening" data-scores='{"herbal":4,"white":1}'>
            <span class="quiz__option-emoji"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg></span>
            <span class="quiz__option-text">{{ 'quiz.q3_o3' | t }}</span>
          </button>
          <button class="quiz__option" data-value="allday" data-scores='{"green":2,"oolong":2,"white":1,"herbal":1}'>
            <span class="quiz__option-emoji"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg></span>
            <span class="quiz__option-text">{{ 'quiz.q3_o4' | t }}</span>
          </button>
        </div>
      </div>

      <!-- Question 4: Brewing Style -->
      <div class="quiz__screen" data-screen="q4" data-question="4">
        <div class="quiz__progress">
          <div class="quiz__progress-bar" style="width: 100%;"></div>
        </div>
        <div class="quiz__step-label">Question 4 of 4</div>
        <h3 class="quiz__question">{{ 'quiz.q4_title' | t }}</h3>
        <div class="quiz__options" data-question="style">
          <button class="quiz__option" data-value="quick" data-scores='{"black":2,"herbal":2,"green":1}'>
            <span class="quiz__option-emoji"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></span>
            <span class="quiz__option-text">{{ 'quiz.q4_o1' | t }}</span>
          </button>
          <button class="quiz__option" data-value="gongfu" data-scores='{"oolong":3,"puerh":3,"green":1}'>
            <span class="quiz__option-emoji"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg></span>
            <span class="quiz__option-text">{{ 'quiz.q4_o2' | t }}</span>
          </button>
          <button class="quiz__option" data-value="coldbrew" data-scores='{"green":3,"white":2,"herbal":1}'>
            <span class="quiz__option-emoji"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="12" y1="2" x2="12" y2="22"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/><line x1="2" y1="12" x2="22" y2="12"/><line x1="4.93" y1="19.07" x2="19.07" y2="4.93"/></svg></span>
            <span class="quiz__option-text">{{ 'quiz.q4_o3' | t }}</span>
          </button>
          <button class="quiz__option" data-value="beginner" data-scores='{"green":2,"black":2,"herbal":2}'>
            <span class="quiz__option-emoji"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg></span>
            <span class="quiz__option-text">{{ 'quiz.q4_o4' | t }}</span>
          </button>
        </div>
      </div>

      <!-- Results Screen -->
      <div class="quiz__screen" data-screen="results">
        <div class="text-center">
          <span class="section-label">{{ 'quiz.result_title' | t }}</span>
          <h2 class="quiz__result-heading" id="quiz-result-title">Your Tea Match</h2>
          <p class="quiz__result-subtitle" id="quiz-result-desc">Loading your results...</p>
        </div>

        <div class="quiz__results-grid" id="quiz-results-grid">
          <!-- Results dynamically injected here -->
        </div>

        <div class="text-center mt-2xl">
          <button class="btn btn--ghost quiz__restart-btn" id="quiz-restart">
            ← {{ 'quiz.restart' | t }}
          </button>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  window.QuizProducts = {};
  {% assign tea_handles = 'uji-sencha-reserve,golden-yunnan-tips,ali-shan-high-mountain,silver-needle-bai-hao,ancient-tree-puerh,chamomile-meadow-blend' | split: ',' %}
  {% assign tea_keys = 'green,black,oolong,white,puerh,herbal' | split: ',' %}
  
  {% for key in tea_keys %}
    {% assign handle = tea_handles[forloop.index0] %}
    {% assign p = all_products[handle] %}
    window.QuizProducts["{{ key }}"] = {
      price: {% if p != blank %}{{ p.price | money | json }}{% else %}null{% endif %},
      url: {% if p != blank %}{{ p.url | json }}{% else %}null{% endif %},
      image: {% if p != blank and p.featured_image != blank %}{{ p.featured_image | image_url: width: 600 | json }}{% else %}null{% endif %},
      variant_id: {% if p != blank %}{{ p.selected_or_first_available_variant.id | json }}{% else %}null{% endif %},
      available: {% if p != blank %}{{ p.available | json }}{% else %}true{% endif %},
      {% assign tracks = false %}
      {% assign inv = 0 %}
      {% if p != blank %}
        {% for v in p.variants %}
          {% if v.inventory_management == 'shopify' %}
            {% assign tracks = true %}
            {% if v.inventory_quantity > 0 %}
              {% assign inv = inv | plus: v.inventory_quantity %}
            {% endif %}
          {% endif %}
        {% endfor %}
      {% endif %}
      tracks_inventory: {{ tracks | json }},
      total_inventory: {{ inv | json }}
    };
  {% endfor %}
  
  // Fallbacks for missing products
  if (!window.QuizProducts['green'].price) window.QuizProducts['green'].price = "₱1,350.00";
  if (!window.QuizProducts['green'].url) window.QuizProducts['green'].url = "/products/uji-sencha-reserve";
  if (!window.QuizProducts['black'].price) window.QuizProducts['black'].price = "₱1,000.00";
  if (!window.QuizProducts['black'].url) window.QuizProducts['black'].url = "/products/golden-yunnan-tips";
  if (!window.QuizProducts['oolong'].price) window.QuizProducts['oolong'].price = "₱1,800.00";
  if (!window.QuizProducts['oolong'].url) window.QuizProducts['oolong'].url = "/products/ali-shan-high-mountain";
  if (!window.QuizProducts['white'].price) window.QuizProducts['white'].price = "₱1,550.00";
  if (!window.QuizProducts['white'].url) window.QuizProducts['white'].url = "/products/silver-needle-bai-hao";
  if (!window.QuizProducts['puerh'].price) window.QuizProducts['puerh'].price = "₱2,500.00";
  if (!window.QuizProducts['puerh'].url) window.QuizProducts['puerh'].url = "/products/ancient-tree-puerh";
  if (!window.QuizProducts['herbal'].price) window.QuizProducts['herbal'].price = "₱900.00";
  if (!window.QuizProducts['herbal'].url) window.QuizProducts['herbal'].url = "/products/chamomile-meadow-blend";
</script>
<script src="{{ 'quiz.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Find Your Tea",
  "class": "section-tea-quiz",
  "settings": [],
  "presets": [
    {
      "name": "Find Your Tea"
    }
  ]
}
{% endschema %}
