{% comment %}
  Verdant Leaf — Footer Section
  Multi-column footer with branding, links, and social icons
{% endcomment %}

<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer__grid">
      <!-- Brand Column -->
      <div class="footer__col">
        <a href="{{ routes.root_url }}" class="header__logo" style="color: var(--color-cream);">
          <img class="header__logo-icon" src="{{ 'verdant-leaf-logo-green.png' | asset_url }}" alt="Verdant Leaf Logo" width="32" height="32" loading="lazy" style="object-fit: contain;">
          <span>Verdant Leaf</span>
        </a>
        <p class="footer__brand-desc">
          {{ 'footer.description' | t }}
        </p>
      </div>

      <!-- Shop Links -->
      <div class="footer__col">
        <h4 class="footer__heading">{{ 'footer.shop' | t }}</h4>
        <nav class="footer__links" aria-label="Shop links">
          <a href="{{ routes.all_products_collection_url }}" class="footer__link">{{ 'footer.links.all_teas' | t }}</a>
          <a href="{{ routes.collections_url }}/green-tea" class="footer__link">{{ 'footer.links.green_tea' | t }}</a>
          <a href="{{ routes.collections_url }}/black-tea" class="footer__link">{{ 'footer.links.black_tea' | t }}</a>
          <a href="{{ routes.collections_url }}/oolong" class="footer__link">{{ 'footer.links.oolong' | t }}</a>
          <a href="{{ routes.collections_url }}/herbal" class="footer__link">{{ 'footer.links.herbal' | t }}</a>
        </nav>
      </div>

      <!-- Company Links -->
      <div class="footer__col">
        <h4 class="footer__heading">{{ 'footer.company' | t }}</h4>
        <nav class="footer__links" aria-label="Company links">
          <a href="/pages/about" class="footer__link">{{ 'footer.links.about' | t }}</a>
          <a href="/pages/sourcing" class="footer__link">{{ 'footer.links.sourcing' | t }}</a>
          <a href="/pages/sustainability" class="footer__link">{{ 'footer.links.sustainability' | t }}</a>
          <a href="/blogs/tea-journal" class="footer__link">{{ 'footer.links.blog' | t }}</a>
        </nav>
      </div>

      <!-- Support Links -->
      <div class="footer__col">
        <h4 class="footer__heading">{{ 'footer.support' | t }}</h4>
        <nav class="footer__links" aria-label="Support links">
          <a href="/pages/faq" class="footer__link">{{ 'footer.links.faq' | t }}</a>
          <a href="/pages/shipping" class="footer__link">{{ 'footer.links.shipping' | t }}</a>
          <a href="/pages/contact" class="footer__link">{{ 'footer.links.contact' | t }}</a>
          <a href="/policies/privacy-policy" class="footer__link">{{ 'footer.links.privacy' | t }}</a>
        </nav>
      </div>
    </div>

    <div class="footer__bottom">
      <p>{{ 'footer.copyright' | t }}</p>

      <div class="footer__social">
        <a href="#" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5"/>
            <circle cx="12" cy="12" r="5"/>
            <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/>
          </svg>
        </a>
        <a href="#" aria-label="Twitter">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/>
          </svg>
        </a>
        <a href="#" aria-label="Pinterest">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2C6.477 2 2 6.477 2 12c0 4.237 2.636 7.855 6.356 9.312-.088-.791-.167-2.005.035-2.868.181-.78 1.172-4.97 1.172-4.97s-.299-.598-.299-1.482c0-1.388.806-2.425 1.808-2.425.853 0 1.265.64 1.265 1.408 0 .858-.546 2.14-.828 3.33-.236.995.5 1.807 1.48 1.807 1.778 0 3.144-1.874 3.144-4.58 0-2.393-1.72-4.068-4.177-4.068-2.845 0-4.515 2.135-4.515 4.34 0 .859.331 1.781.745 2.282a.3.3 0 01.069.288l-.278 1.133c-.044.183-.145.222-.335.134-1.249-.581-2.03-2.407-2.03-3.874 0-3.154 2.292-6.052 6.608-6.052 3.469 0 6.165 2.473 6.165 5.776 0 3.447-2.173 6.22-5.19 6.22-1.013 0-1.966-.527-2.292-1.148l-.623 2.378c-.226.869-.835 1.958-1.244 2.621.937.29 1.931.446 2.962.446 5.523 0 10-4.477 10-10S17.523 2 12 2z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "class": "section-footer"
}
{% endschema %}
