{% comment %}
  Verdant Leaf — Product Card Snippet
  Reusable product card used in collection and featured collection sections
  
  Usage: {% render 'product-card', product: product %}
{% endcomment %}

{% assign product_type_handle = product.type | handleize %}
{% if product_type_handle == 'pu-erh' %}
  {% assign product_type_handle = 'puerh' %}
{% endif %}
{% if product_type_handle == blank %}
  {% assign product_tags = product.tags | join: ' ' %}
  {% assign product_lookup = product.title | append: ' ' | append: product_tags | downcase %}
  {% if product_lookup contains 'matcha' %}
    {% assign product_type_handle = 'matcha' %}
  {% elsif product_lookup contains 'puerh' or product_lookup contains 'pu-erh' %}
    {% assign product_type_handle = 'puerh' %}
  {% elsif product_lookup contains 'oolong' %}
    {% assign product_type_handle = 'oolong' %}
  {% elsif product_lookup contains 'white' %}
    {% assign product_type_handle = 'white' %}
  {% elsif product_lookup contains 'black' or product_lookup contains 'darjeeling' %}
    {% assign product_type_handle = 'black' %}
  {% elsif product_lookup contains 'herbal' or product_lookup contains 'chamomile' %}
    {% assign product_type_handle = 'herbal' %}
  {% elsif product_lookup contains 'green' or product_lookup contains 'sencha' or product_lookup contains 'jasmine' %}
    {% assign product_type_handle = 'green' %}
  {% endif %}
{% endif %}

{% assign product_origin = product.metafields.custom.origin | default: product.vendor %}
{% assign product_type_label = product.type | default: 'Tea' %}
{% assign visual_tone = product_type_handle | default: 'green' %}
{% if visual_tone == 'white' or visual_tone == 'green' or visual_tone == 'black' or visual_tone == 'oolong' or visual_tone == 'puerh' or visual_tone == 'herbal' or visual_tone == 'matcha' %}
  {% assign visual_tone = visual_tone %}
{% else %}
  {% assign visual_tone = 'green' %}
{% endif %}

<div class="product-card" data-type="{{ product_type_handle }}">
  <a href="{{ product.url }}" class="product-card__link" aria-label="{{ product.title }}">
    <div class="product-card__image-wrapper">
      {% if product.featured_image %}
        <img
          src="{{ product.featured_image | image_url: width: 600 }}"
          alt="{{ product.featured_image.alt | default: product.title | escape }}"
          class="product-card__image"
          loading="lazy"
          width="600"
          height="600"
        >
      {% else %}
        <div class="product-card__image tea-product-visual tea-product-visual--{{ visual_tone }}">
          <div class="tea-product-visual__tin">
            <span class="tea-product-visual__mark"></span>
            <span class="tea-product-visual__label">{{ product_type_label }}</span>
            <span class="tea-product-visual__origin">{{ product_origin | default: 'Verdant Leaf' }}</span>
          </div>
          <div class="tea-product-visual__scoop"></div>
          <div class="tea-product-visual__leaves tea-product-visual__leaves--one"></div>
          <div class="tea-product-visual__leaves tea-product-visual__leaves--two"></div>
        </div>
      {% endif %}

      {% if product.available == false %}
        <span class="card__tag" style="background: var(--color-charcoal-light); color: white; position: absolute; top: 12px; left: 12px; padding: 4px 10px; border-radius: 4px; font-size: 12px; font-weight: bold; z-index: 2;">Sold Out</span>
      {% elsif product.compare_at_price > product.price %}
        <span class="card__tag" style="background: var(--color-error); color: white; position: absolute; top: 12px; left: 12px; padding: 4px 10px; border-radius: 4px; font-size: 12px; font-weight: bold; z-index: 2;">Sale</span>
      {% elsif product.tags contains 'new' %}
        <span class="card__tag" style="background: var(--color-gold); color: var(--color-forest-dark); position: absolute; top: 12px; left: 12px; padding: 4px 10px; border-radius: 4px; font-size: 12px; font-weight: bold; z-index: 2;">New</span>
      {% endif %}
      
    </div>

    <div class="product-card__body">
      {% if product.type != blank or product_origin != blank %}
        <div class="product-card__category">
          {{ product_origin | default: 'Verdant Leaf' }}
          {% if product.type != blank %}
            · {{ product.type }}
          {% endif %}
        </div>
      {% endif %}
      <h3 class="product-card__title">{{ product.title }}</h3>
      
      {% assign total_inventory = 0 %}
      {% assign tracks_inventory = false %}
      {% for variant in product.variants %}
        {% if variant.inventory_management == 'shopify' %}
          {% assign tracks_inventory = true %}
          {% if variant.inventory_quantity > 0 %}
            {% assign total_inventory = total_inventory | plus: variant.inventory_quantity %}
          {% endif %}
        {% endif %}
      {% endfor %}

      <div class="product-card__price-and-stock" style="display: flex; justify-content: space-between; align-items: center; margin-top: 12px; margin-bottom: 4px;">
        <div class="product-card__price" style="font-weight: 700; color: var(--color-forest-dark); font-size: 16px;">
          {% render 'price', product: product %}
        </div>
        <div class="product-card__stock" style="font-size: 13px; text-align: right;">
          {% if tracks_inventory %}
            {% if total_inventory > 0 %}
              {% if total_inventory <= 5 %}
                <span style="color: var(--color-error); font-weight: 600;">Only {{ total_inventory }} left in stock</span>
              {% else %}
                <span style="color: var(--color-forest-light);">{{ total_inventory }} in stock</span>
              {% endif %}
            {% elsif product.available == false %}
              <span style="color: var(--color-error);">Out of stock</span>
            {% endif %}
          {% elsif product.available %}
            <span style="color: var(--color-forest-light);">In stock</span>
          {% else %}
            <span style="color: var(--color-error);">Out of stock</span>
          {% endif %}
        </div>
      </div>
    </div>
  </a>

  {% if product.available %}
    {% assign card_variant_id = product.selected_or_first_available_variant.id %}
    <div class="product-card__actions">
      <button class="product-card__btn product-card__btn--cart" type="button" aria-label="{{ 'product.add_to_cart' | t }}" onclick="fetch('{{ routes.cart_add_url }}.js', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ items: [{ id: {{ card_variant_id }}, quantity: 1 }] }) }).then(() => window.location.href = '{{ routes.cart_url }}')">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px;">
          <circle cx="9" cy="21" r="1"></circle>
          <circle cx="20" cy="21" r="1"></circle>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
        </svg>
        <span class="btn-text">Add</span>
      </button>
      <button class="product-card__btn product-card__btn--buy" type="button" aria-label="{{ 'product.buy_now' | t }}" onclick="fetch('{{ routes.cart_add_url }}.js', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ items: [{ id: {{ card_variant_id }}, quantity: 1 }] }) }).then(() => window.location.href = '{{ routes.checkout_url | default: '/checkout' }}')">
        <span class="btn-text btn-text--desktop">Buy Now</span>
        <span class="btn-text btn-text--mobile">Buy</span>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left: 6px;">
          <path d="M5 12h14"></path>
          <path d="M12 5l7 7-7 7"></path>
        </svg>
      </button>
    </div>
  {% endif %}
</div>
