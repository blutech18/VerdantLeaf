# FreshTrack Environment Variables
# Copy this file to .env and fill in your values

# Shopify Partner app (OAuth + embedded flow — required)
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
VITE_SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_SHOP_DOMAIN=verdantleafshop.myshopify.com

# Secret used to encrypt OAuth access tokens at rest (AES-256-GCM).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Falls back to SHOPIFY_API_SECRET if unset (fine for local dev, set this in prod).
TOKEN_ENCRYPTION_KEY=

# Set to "production" to require a valid Shopify session token on every API call.
# Leave unset/development to allow the local demo (store id 1) without a tunnel.
# (Uses APP_ENV instead of NODE_ENV so Vite doesn't warn when building the frontend.)
APP_ENV=development

# Server — when tunneling (ngrok / cloudflared), set BOTH to the SAME public
# HTTPS URL the tunnel gives you, and update the App URL + redirect URL in the
# Partner dashboard to match. A stale tunnel URL causes ERR_NAME_NOT_RESOLVED.
PORT=3000
HOST=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Set true when using ngrok so product webhooks register on OAuth install
SHOPIFY_FORCE_WEBHOOKS=false

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=freshtrack
